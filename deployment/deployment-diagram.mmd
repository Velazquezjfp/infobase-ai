---
title: BAMF ACTE Companion - Kubernetes Deployment Architektur
---
flowchart TB
    Browser["Browser<br/>(HTTPS)"]

    subgraph K8s["Kubernetes Cluster"]
        direction TB

        subgraph Ingress["Ingress Layer"]
            NginxIngress["NGINX Ingress Controller<br/>acte.bamf.internal<br/>TLS Terminierung"]
        end

        subgraph ACTE["ACTE Companion"]
            direction TB
            Frontend["Frontend<br/>React 18 + NGINX<br/>Port 80<br/>(x2 Replicas)"]
            Backend["Backend<br/>FastAPI + Uvicorn<br/>Port 8000 - Python 3.12<br/>10 REST Router + WebSocket<br/>(x2 Replicas)"]
        end

        subgraph AnonSvc["Anonymisierungsdienst"]
            Anon["Flask + PyTorch<br/>Port 5000 - Python 3.10<br/>SpaCy NER + EasyOCR + YOLO<br/>CPU-only Inferenz<br/>Image: ~8.4 GB"]
        end

        subgraph IDIRSSvc["IDIRS Document Search"]
            direction TB
            IDIRSApi["API Server<br/>FastAPI + Uvicorn<br/>Port 8010 - Python 3.12"]
            OpenSearch["OpenSearch<br/>Port 9200<br/>BM25 + kNN Index<br/>PVC: 10Gi"]
            Pipeline["Data Pipeline<br/>Python 3.12<br/>docling + rdflib<br/>(Job - einmalig)"]
        end

        subgraph LLMChoice["LLM Service fuer IDIRS"]
            direction TB
            Ollama["Option A: Ollama<br/>Port 11434<br/>gemma3:12b + nomic-embed<br/>GPU: NVIDIA 16GB VRAM<br/>RAM: 12-16Gi"]
            ExtLLM["Option B: Externe API<br/>z.B. OpenAI / Anthropic<br/>Kein Pod noetig<br/>Kein GPU noetig"]
        end

        subgraph Storage["Persistenter Speicher"]
            DocPVC["Dokumenten-PVC<br/>10Gi RWX<br/>PDF / Bilder / E-Mails"]
            CasePVC["Case-Daten-PVC<br/>5Gi RWX<br/>JSON Konfiguration"]
        end

        subgraph Config["Konfiguration"]
            ConfigMap["ConfigMap<br/>acte-config"]
            Secret["Secrets<br/>GEMINI_API_KEY<br/>ANONYMIZATION_SECRET"]
        end
    end

    subgraph CloudSvc["Cloud-Dienste"]
        Gemini["Google Gemini API<br/>gemini-2.5-flash<br/>HTTPS Port 443"]
    end

    %% Browser zu Ingress
    Browser -->|"HTTPS"| NginxIngress

    %% Ingress zu Services
    NginxIngress -->|"Statische Dateien /"| Frontend
    NginxIngress -->|"/api/* und /ws/*"| Backend

    %% ACTE Backend Verbindungen
    Backend -->|"HTTP :5000"| Anon
    Backend -->|"HTTP :8010"| IDIRSApi
    Backend -->|"HTTPS :443"| Gemini
    Backend <-->|"Lesen/Schreiben"| DocPVC
    Backend <-->|"Lesen/Schreiben"| CasePVC
    Backend -.->|"Liest"| ConfigMap
    Backend -.->|"Liest"| Secret

    %% IDIRS interne Verbindungen
    IDIRSApi -->|"HTTP :9200"| OpenSearch
    IDIRSApi -->|"HTTP :11434"| Ollama
    Pipeline -->|"HTTP :9200"| OpenSearch
    Pipeline -->|"HTTP :11434"| Ollama

