        "Defines ToasterToast type extending ToastProps",
        "Defines actionTypes: ADD_TOAST, UPDATE_TOAST, DISMISS_TOAST, REMOVE_TOAST",
        "Implements toast queue with TOAST_LIMIT of 1",
        "Uses memory state pattern for cross-component toast management",
        "Returns toasts array, toast function, dismiss function"
      ]
    },
    {
      "name": "src/hooks/use-mobile.tsx",
      "entityType": "Hook",
      "observations": [
        "Mobile detection hook",
        "Exports useIsMobile custom hook",
        "Uses React useState and useEffect",
        "Defines MOBILE_BREAKPOINT constant at 768px",
        "Uses window.matchMedia for responsive detection",
        "Adds and removes event listener for resize changes",
        "Returns boolean indicating mobile viewport"
      ]
    },
