  "paths": {
    "/api/admin/generate-field": {
      "post": {
        "tags": [
          "Admin"
        ],
        "summary": "Generate form field from natural language",
        "description": "Generate a SHACL-compliant form field specification from a natural language prompt.\n\nThe service uses rule-based extraction for common patterns and falls back to AI\n(Gemini) for more complex or ambiguous requests.\n\n**Supported field types:**\n- text: Standard text input\n- date: Date picker\n- select: Dropdown with options\n- textarea: Multi-line text\n\n**Supported languages:** English, German\n",
        "operationId": "generateField",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "prompt"
                ],
                "properties": {
                  "prompt": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 500,
                    "description": "Natural language description of the desired field",
                    "example": "Add a dropdown for marital status with options single, married, divorced"
                  }
                }
              },
              "examples": {
                "textField": {
                  "summary": "Text field example",
                  "value": {
                    "prompt": "Add a required text field for passport number"
                  }
                },
                "selectField": {
                  "summary": "Select field example",
                  "value": {
                    "prompt": "Add dropdown for education level with options high school, bachelor, master"
                  }
                },
                "dateField": {
                  "summary": "Date field example",
                  "value": {
                    "prompt": "Create a date field for visa expiry date"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Field generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "field": {
                      "$ref": "#/components/schemas/GeneratedField"
                    },
                    "message": {
                      "type": "string",
                      "example": "Successfully generated 'Marital Status' field"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request or generation failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": {
                      "type": "object",
                      "properties": {
                        "error": {
                          "type": "string",
                          "example": "Field generation failed"
                        },
                        "detail": {
                          "type": "string",
                          "example": "Prompt is too short or ambiguous"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "x-source-file": "backend/api/admin.py"
      }
    },
