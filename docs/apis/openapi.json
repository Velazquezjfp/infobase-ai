    "title": "BAMF ACTE Companion API",
    "description": "API specification for the BAMF ACTE (Automated Case and Task Environment) Companion application.\n\n**Current Status:** This is a PLANNED API specification. The application currently operates as a\nfrontend-only prototype with simulated operations. This specification documents the target\narchitecture for future backend implementation.\n\nThe API will provide document management, AI-powered case processing, and integration course\napplication handling for BAMF (Bundesamt f\u00fcr Migration und Fl\u00fcchtlinge).\n",
    "version": "1.4.0",
    "contact": {
      "name": "BAMF Development Team",
      "email": "api@bamf.example.de"
    },
    "license": {
      "name": "Proprietary"
    }
  },
  "servers": [
    {
      "url": "https://api.bamf-acte.example.de/v1",
      "description": "Production server (planned)"
    },
    {
      "url": "https://staging-api.bamf-acte.example.de/v1",
      "description": "Staging server (planned)"
    },
    {
      "url": "http://localhost:3000/api/v1",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Admin",
      "description": "Administrative operations and form field generation"
    },
    {
      "name": "Authentication",
      "description": "User authentication and authorization"
    },
    {
      "name": "Cases",
      "description": "Case management operations"
    },
    {
      "name": "Documents",
      "description": "Document upload, conversion, and retrieval"
