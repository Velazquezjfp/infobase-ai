  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token obtained from /auth/login endpoint"
      }
    },
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "required": [
          "accessToken",
          "tokenType",
          "expiresIn",
          "user"
        ],
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT access token",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "tokenType": {
            "type": "string",
            "example": "Bearer"
          },
          "expiresIn": {
            "type": "integer",
            "description": "Token expiration time in seconds",
            "example": 3600
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh token for obtaining new access token"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "User": {
        "type": "object",
        "required": [
          "id",
          "username",
          "role"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "user-123"
          },
          "username": {
            "type": "string",
            "example": "bamf.officer@example.de"
          },
          "name": {
            "type": "string",
            "example": "Maria Schmidt"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "officer",
              "viewer"
            ],
            "example": "officer"
          }
        }
      },
      "Case": {
        "type": "object",
        "required": [
          "id",
          "name",
          "createdAt",
          "status",
          "folders"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique case identifier",
            "example": "ACTE-2024-001"
          },
          "name": {
            "type": "string",
            "description": "Case name/title",
            "example": "German Integration Course Application - Ahmed Ali"
          },
          "createdAt": {
            "type": "string",
            "format": "date",
            "description": "Case creation date",
            "example": "2024-01-15"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "pending",
              "completed"
            ],
            "description": "Current case status",
            "example": "open"
          },
          "folders": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Folder"
            }
          }
        }
      },
      "Folder": {
        "type": "object",
        "required": [
          "id",
          "name",
          "documents",
          "subfolders"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "personal-data"
          },
          "name": {
            "type": "string",
            "example": "Personal Data"
          },
          "isExpanded": {
            "type": "boolean",
            "default": false
          },
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Document"
            }
          },
          "subfolders": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Folder"
            }
          }
        }
      },
      "Document": {
        "type": "object",
        "required": [
          "id",
          "name",
          "type",
          "size",
          "uploadedAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "doc-1"
          },
          "name": {
            "type": "string",
            "example": "Birth_Certificate.pdf"
          },
          "type": {
            "type": "string",
            "enum": [
              "pdf",
              "xml",
              "json",
              "docx"
            ],
            "example": "pdf"
          },
          "size": {
            "type": "string",
            "description": "Human-readable file size",
            "example": "245 KB"
          },
          "uploadedAt": {
            "type": "string",
            "format": "date",
            "example": "2024-01-15"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "description": "Document-specific metadata"
          },
          "content": {
            "type": "string",
            "description": "Document content (for text documents)"
          }
        }
      },
      "FormField": {
        "type": "object",
        "required": [
          "id",
          "label",
          "type",
          "value"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "name"
          },
          "label": {
            "type": "string",
            "example": "Full Name"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "date",
              "select",
              "textarea"
            ],
            "example": "text"
          },
          "value": {
            "type": "string",
            "example": "Ahmed Ali"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Available options for select fields"
          },
          "required": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "GeneratedField": {
        "type": "object",
        "required": [
          "id",
          "label",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique field identifier in camelCase",
            "example": "maritalStatus"
          },
          "label": {
            "type": "string",
            "description": "Human-readable field label",
            "example": "Marital Status"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "date",
              "select",
              "textarea"
            ],
            "description": "Field type",
            "example": "select"
          },
          "value": {
            "type": "string",
            "description": "Default field value (usually empty)",
            "default": ""
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Available options for select fields",
            "example": [
              "single",
              "married",
              "divorced"
            ]
          },
          "required": {
            "type": "boolean",
            "description": "Whether the field is required",
            "default": false
          },
          "shaclMetadata": {
            "type": "object",
            "description": "SHACL semantic metadata in JSON-LD format",
            "properties": {
              "@context": {
                "type": "object",
                "description": "JSON-LD context with namespace prefixes",
                "properties": {
                  "sh": {
                    "type": "string",
                    "example": "http://www.w3.org/ns/shacl#"
                  },
                  "schema": {
                    "type": "string",
                    "example": "http://schema.org/"
                  },
                  "xsd": {
                    "type": "string",
                    "example": "http://www.w3.org/2001/XMLSchema#"
                  }
                }
              },
              "@type": {
                "type": "string",
                "description": "SHACL type",
                "example": "sh:PropertyShape"
              },
              "sh:path": {
                "type": "string",
                "description": "Semantic property path",
                "example": "schema:maritalStatus"
              },
              "sh:datatype": {
                "type": "string",
                "description": "XSD datatype",
                "example": "xsd:string"
              },
              "sh:name": {
                "type": "string",
                "description": "Human-readable name",
                "example": "Marital Status"
              },
              "sh:description": {
                "type": "string",
                "description": "Field description",
                "example": "The person's marital status"
              },
              "sh:minCount": {
                "type": "integer",
                "description": "Minimum cardinality (1 = required)",
                "example": 1
              },
              "sh:maxCount": {
                "type": "integer",
                "description": "Maximum cardinality (1 = single value)",
                "example": 1
              },
              "sh:in": {
                "type": "object",
                "description": "Allowed values for select fields",
                "properties": {
                  "@list": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      "single",
                      "married",
                      "divorced"
                    ]
                  }
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string",
            "example": "UNAUTHORIZED"
          },
          "message": {
            "type": "string",
            "example": "Invalid credentials provided"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
