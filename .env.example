# BAMF ACTE Companion — environment configuration template
#
# Copy this file to `.env` at the repository root and fill in real values.
# Backend, frontend, and docker-compose all read from the same `.env`.
#
# Conventions:
#   - 🔒 marks sensitive values (treat as secret; never commit real values)
#   - "(required)" means the application will not start without a value
#   - "introduced by S001-..." traces the variable to its sprint requirement
#
# This file contains placeholders only. No real credentials.


# Section: Registry & package sources
# -----------------------------------------------------------------------------
# Defaults point at public sources for local dev. In production (BDOP layer)
# these are overridden to point at the internal Artifactory mirrors.

# Type: URL
# Default: docker.io
# Purpose: registry used by Docker build and Compose to pull base images.
# introduced by S001-D-001
DOCKER_REGISTRY=docker.io

# Type: URL
# Default: https://registry.npmjs.org/
# Purpose: npm registry used by the frontend build to install JS dependencies.
# introduced by S001-D-001
NPM_REGISTRY=https://registry.npmjs.org/

# Type: URL
# Default: https://pypi.org/simple/
# Purpose: pip index used by the backend build to install Python dependencies.
# introduced by S001-D-001
PIP_INDEX_URL=https://pypi.org/simple/


# Section: LLM backend
# -----------------------------------------------------------------------------
# Selects which LLM provider the backend talks to. `internal` routes through
# the local LiteLLM proxy (closed-environment deployment); `external` calls
# Google Gemini directly using GEMINI_API_KEY.

# Type: enum (internal | external)
# Default: external
# Purpose: selects the LLM provider — `internal` uses the LiteLLM proxy, `external` uses Gemini.
# introduced by S001-F-001
LLM_BACKEND=external

# Type: URL
# Default: http://localhost:4000
# Purpose: base URL of the LiteLLM proxy (only used when LLM_BACKEND=internal).
# introduced by S001-F-001
LITELLM_PROXY_URL=http://localhost:4000

# 🔒
# Type: string
# Default: (required when LLM_BACKEND=internal)
# Purpose: bearer token presented to the LiteLLM proxy.
# introduced by S001-F-001
LITELLM_TOKEN=replace-me

# Type: string
# Default: gemma3:12b
# Purpose: model identifier the LiteLLM proxy should route to.
# introduced by S001-F-001
LITELLM_MODEL=gemma3:12b

# Type: boolean
# Default: false
# Purpose: when true, docker-compose starts the optional local Ollama container.
# introduced by S001-F-002
ENABLE_OLLAMA_CONTAINER=false

# 🔒
# Type: string
# Default: (required when LLM_BACKEND=external)
# Purpose: Google Gemini API key used by the external-LLM path.
# introduced by S001-F-001
GEMINI_API_KEY=replace-me


# Section: Feature flags for stubbed-out subsystems
# -----------------------------------------------------------------------------
# Sprint 1 ships the closed-environment build with these subsystems disabled
# and replaced by user-facing notices. Set to `true` only in environments
# where the corresponding service is reachable.

# Type: boolean
# Default: false
# Purpose: enables PII anonymization via the external service; off shows a notice.
# introduced by S001-F-004
ENABLE_ANONYMIZATION=false

# Type: boolean
# Default: false
# Purpose: enables IDIRS document search and RAG; off shows a notice.
# introduced by S001-F-005
ENABLE_DOCUMENT_SEARCH=false

# Type: boolean
# Default: false
# Purpose: enables file uploads; off hides upload UI and shows a notice.
# introduced by S001-F-006
ENABLE_UPLOAD=false


# Section: Session lifecycle
# -----------------------------------------------------------------------------
# One-shot ephemeral session — root_docs is reset on logout, browser close,
# or after the configured idle timeout.

# Type: integer (minutes)
# Default: 10
# Purpose: idle timeout after which the ephemeral session is reset.
# introduced by S001-F-007
SESSION_IDLE_TIMEOUT_MINUTES=10


# Section: Ports & paths
# -----------------------------------------------------------------------------
# Network ports exposed by Compose and filesystem paths used by both the
# backend and the document store. Keep these aligned with any reverse-proxy
# or volume-mount configuration in the BDOP layer.

# Type: integer (TCP port)
# Default: 8000
# Purpose: TCP port the FastAPI backend listens on.
# introduced by S001-D-001
BACKEND_PORT=8000

# Type: integer (TCP port)
# Default: 3000
# Purpose: TCP port the Vite frontend serves on (production build).
# introduced by S001-D-001
FRONTEND_PORT=3000

# Type: string (filesystem path)
# Default: public/documents
# Purpose: base path for document storage; in containers mount as a volume.
# introduced by S001-D-001
DOCUMENTS_PATH=public/documents

# Type: enum (DEBUG | INFO | WARNING | ERROR | CRITICAL)
# Default: INFO
# Purpose: application log verbosity for the Python `logging` module.
# introduced by S001-D-001
LOG_LEVEL=INFO

# Type: URL
# Default: http://localhost:8010
# Purpose: base URL of the IDIRS service used for hybrid search and RAG.
# introduced by S001-D-001
IDIRS_BASE_URL=http://localhost:8010

# Type: boolean
# Default: false
# Purpose: when true, auto-initialises the test document set for ACTE-2024-001 on startup.
# introduced by S001-D-001
INIT_TEST_DOCS=false

# Type: boolean (string "1"/"0")
# Default: 1
# Purpose: when "1", skips integration tests that depend on the external anonymization service.
# introduced by S001-D-001
SKIP_INTEGRATION_TESTS=1
